# EditorConfig encodes the conventions already enforced by rustfmt and used in
# the frontend, so editors and AI agents stay consistent without extra tooling.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Rust uses rustfmt's 4-space indent.
[*.rs]
indent_size = 4

# just recipes are indented with 4 spaces (see justfile).
[justfile]
indent_size = 4

# Markdown can use trailing spaces for hard line breaks.
[*.md]
trim_trailing_whitespace = false
