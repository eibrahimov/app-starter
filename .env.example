# Port the API + UI server binds to
PORT=8080
# SQLite database location. mode=rwc creates the file on first run.
DATABASE_URL=sqlite://data/app.db?mode=rwc
# Log filter (tracing-subscriber EnvFilter syntax)
RUST_LOG=info,app_starter=debug
# Optional: seed the example todo + blog plugins on startup (off by default). Accepts
# 1/true/yes/on. Equivalent to `--seed` or `just seed`; see src/seed.rs.
# SEED=1
