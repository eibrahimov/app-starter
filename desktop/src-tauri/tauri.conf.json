{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Expense Tracker",
  "version": "0.1.1",
  "identifier": "com.example.expense-tracker",
  "build": {
    "beforeDevCommand": "cd ../interface && bun install && bun run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd ../interface && bun install && bun run build",
    "frontendDist": "../../interface/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Expense Tracker",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage", "app", "dmg", "nsis", "msi"],
    "externalBin": ["binaries/app-starter"],
    "icon": ["icons/icon.png"]
  }
}
