#!/usr/bin/env bash
set -eu
staged=$(git diff --cached --name-only --diff-filter=ACMR -- '*.rs')
[ -z "$staged" ] && exit 0
echo "pre-commit: cargo fmt --all -- --check"
if ! cargo fmt --all -- --check; then
  echo "pre-commit: formatting issues found. Run 'cargo fmt --all' and re-stage." >&2
  exit 1
fi
